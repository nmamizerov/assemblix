# Minimal prod start — the only two values the API refuses to boot without.
# Everything else has a working default; see .env.example for the full set.
# Copy to .env and fill both: cp .env.example.quick .env
JWT_SECRET_KEY=        # min 32 chars. gen: python -c "import secrets;print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY=        # Fernet key.   gen: python generate_encryption_key.py
