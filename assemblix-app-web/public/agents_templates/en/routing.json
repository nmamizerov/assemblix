    {
      "id": "node-1768367074328-18",
      "type": "agent",
      "config": {
        "name": "Handle Negative Response",
        "model": "gpt-4.1-nano",
        "tools": null,
        "provider": "openai",
        "tool_choice": "auto",
        "instructions": [
          {
            "role": "user",
            "content": "You are an empathetic support specialist. The customer has expressed dissatisfaction. Your task: 1. Express sincere regret and understanding 2. Ask 2-3 clarifying questions to understand the root of the problem 3. Be specific - ask for details (when it happened, what exactly is not working, what steps were taken) Tone: professional, empathetic, but not overly formal Style: short sentences, clear questions Do NOT suggest solutions at this stage - only gather information. Show that you genuinely want to help resolve the issue."
          }
        ],
        "credential_id": "",
        "response_format": "text",
        "response_schema": null
      },
      "position": {
        "x": 904.2410826199957,
