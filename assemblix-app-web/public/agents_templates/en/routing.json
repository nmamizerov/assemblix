      "config": {
        "name": "Handle Positive Response",
        "model": "gpt-4.1-nano",
        "tools": null,
        "provider": "openai",
        "tool_choice": "auto",
        "instructions": [
          {
            "role": "user",
            "content": "The customer left a positive review. Your task is to motivate further action.\n\nAlgorithm:\n\n1. Thank sincerely and personally (mention what specifically was appreciated)\n\n2. Delicately ask to share the review publicly (if not yet shared)\n\n3. Suggest 1-2 simple next steps:\n\n   - Leave a review on a platform (specify where)\n\n   - Tell friends/colleagues\n\n   - Subscribe to updates\n\nTone: grateful, friendly, not pushy\n\nFormat: short response (3-5 sentences)\n\nDo NOT be overly enthusiastic. Be warmly professional."
          }
        ],
        "credential_id": "",
        "response_format": "text",
        "response_schema": null
