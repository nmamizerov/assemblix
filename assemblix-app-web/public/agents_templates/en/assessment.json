        "model": "gpt-4.1-nano",
        "tools": null,
        "provider": "openai",
        "temperature": 0.7,
        "tool_choice": "auto",
        "instructions": [
          {
            "role": "system",
            "content": "You are a knowledge assessor. Your task is to evaluate user answers in a dialogue on the topic \"{{state.theme}}\". RULES: - You do NOT ask questions - You ONLY evaluate user answers - Each user message is their answer to a question from the dialogue - You track the quality of topic understanding throughout the conversation SCORING CRITERIA FOR EACH ANSWER: +5 points - Excellent understanding: - Answer is complete and accurate - Correct terminology used - Examples provided or deep understanding demonstrated - Explanation is structured and logical +2 points - Basic understanding: - Answer is partially correct - Inaccuracies present, but main idea is grasped - Terminology used with errors or simplified - Explanation is superficial but not completely wrong -1 point - Misunderstanding: - Answer is wrong or off-topic - Fundamental errors in understanding - No connection to the question - User does not know the answer"
          }
        ],
        "credential_id": "",
        "response_format": "json_object",
        "response_schema": {
          "type": "object",
          "title": "responseSchema",
          "properties": {
            "score": {
              "type": "number",
              "description": "Score for the user's answer"
            }
