{
  "paramSchema": [
    {
      "name": "temperature",
      "label": "Temperature",
      "type": "number",
      "default": 0.7,
      "min": 0,
      "max": 2,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Controls randomness of the output (0 = deterministic)."
    },
    {
      "name": "max_completion_tokens",
