      "hide": {
        "capability": [
          "reasoning"
        ]
      }
    },
    {
      "name": "top_p",
      "label": "Top P",
      "type": "number",
      "default": 1,
      "min": 0,
      "max": 1,
      "advanced": true,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Nucleus sampling cutoff. 1 disables nucleus sampling."
    },
    {
      "name": "frequency_penalty",
      "label": "Frequency Penalty",
      "type": "number",
      "default": 0,
      "min": -2,
      "max": 2,
      "advanced": true,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Reduces repetition of frequent tokens."
    },
    {
      "name": "presence_penalty",
      "label": "Presence Penalty",
      "type": "number",
      "default": 0,
      "min": -2,
      "max": 2,
      "advanced": true,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Encourages exploring new topics."
    },
    {
      "name": "reasoning_effort",
      "label": "Reasoning Effort",
      "type": "select",
      "default": "off",
      "options": [
        {
          "label": "Off",
          "value": "off"
        },
        {
          "label": "Minimal",
          "value": "minimal",
          "show": {
            "capability": ["reasoning_effort_minimal"]
          }
        },
        {
          "label": "Low",
          "value": "low"
        },
        {
          "label": "Medium",
          "value": "medium"
        },
        {
          "label": "High",
          "value": "high"
        },
        {
          "label": "X-High",
          "value": "xhigh",
          "show": {
            "capability": ["reasoning_effort_xhigh"]
          }
        }
      ],
      "show": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "How much computation the reasoning model spends."
    },
    {
      "name": "response_format",
      "label": "Response Format",
      "type": "select",
      "default": "text",
      "options": [
        {
          "label": "Text",
          "value": "text"
        },
        {
          "label": "JSON object",
          "value": "json_object"
        }
      ],
      "description": "Force the model to return plain text or JSON."
    }
  ],
