{
  "paramSchema": [
    {
      "name": "temperature",
      "label": "Temperature",
      "type": "number",
      "default": 0.7,
      "min": 0,
      "max": 2,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Controls randomness of the output."
    },
    {
      "name": "max_tokens",
      "label": "Max Tokens",
      "type": "number",
      "default": 4096,
      "min": 1,
      "description": "Maximum number of tokens to generate."
    },
    {
      "name": "top_p",
      "label": "Top P",
      "type": "number",
      "default": 1,
      "min": 0,
      "max": 1,
      "advanced": true,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Nucleus sampling cutoff."
    },
    {
      "name": "frequency_penalty",
      "label": "Frequency Penalty",
      "type": "number",
      "default": 0,
      "min": -2,
      "max": 2,
      "advanced": true,
      "hide": {
        "capability": [
          "reasoning"
        ]
      },
      "description": "Reduces repetition of frequent tokens."
    },
    {
      "name": "response_format",
      "label": "Response Format",
      "type": "select",
      "default": "text",
      "options": [
        {
          "label": "Text",
          "value": "text"
        },
        {
          "label": "JSON object",
          "value": "json_object"
        }
      ],
      "description": "Force the model to return plain text or JSON."
    }
  ],
