{
  "paramSchema": [
    {
      "name": "temperature",
      "label": "Temperature",
      "type": "number",
      "default": 1.0,
      "min": 0,
      "max": 1,
      "description": "Controls randomness (Anthropic recommends 0–1)."
    },
    {
      "name": "max_tokens",
      "label": "Max Tokens",
      "type": "number",
      "default": 4096,
      "min": 1,
      "description": "Maximum number of tokens to generate."
    },
    {
      "name": "top_p",
      "label": "Top P",
      "type": "number",
      "default": 1,
      "min": 0,
      "max": 1,
      "advanced": true,
      "description": "Nucleus sampling cutoff."
    },
    {
      "name": "top_k",
      "label": "Top K",
      "type": "number",
      "min": 1,
      "advanced": true,
      "description": "Restrict sampling to the top K tokens."
    },
    {
      "name": "thinking_budget",
      "label": "Thinking Budget",
      "type": "number",
      "default": 2048,
      "min": 1024,
      "advanced": true,
      "show": {
        "capability": [
          "thinking"
        ]
      },
      "description": "Token budget reserved for extended thinking. Available on Claude 4 thinking-capable models."
    },
    {
      "name": "response_format",
      "label": "Response Format",
      "type": "select",
      "default": "text",
      "options": [
        {
          "label": "Text",
          "value": "text"
        },
        {
          "label": "JSON object",
          "value": "json_object"
        }
      ],
      "description": "Force the model to return plain text or JSON."
    }
  ],
